# Copy this file to .env and fill in real values for local development.
# On Replit these are set via the Secrets pane and injected automatically.
# Never commit a real .env to git.

# ── Core ────────────────────────────────────────────────────────────────────
# Postgres connection string used by the API server and Drizzle.
DATABASE_URL=postgresql://user:password@localhost:5432/gym_tracker
# Random string used to sign sessions / cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# ── API server runtime ─────────────────────────────────────────────────────
# Port the API server binds to. Replit sets this automatically per artifact.
PORT=8080
# "development" or "production". Some middleware (Clerk proxy, logger) only
# activates in production.
NODE_ENV=development
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# CORS allow-list for the API server (comma separated). For local dev set
# this to the web app's dev origin so the browser can call the API.
# Comment this line out (do NOT leave it as an empty string) if you want
# the server to fall back to its built-in default.
ALLOWED_ORIGIN=http://localhost:5173
# Path prefix the artifact is served under (e.g. "/" or "/gym-tracker").
# Used by Vite and the mobile build; usually leave as "/" outside Replit.
BASE_PATH=/

# ── Clerk auth (server) ────────────────────────────────────────────────────
# Get these from the Auth pane in Replit, or from clerk.com if running outside.
# Use sk_test/pk_test locally. Use sk_live/pk_live for production and store builds.
CLERK_SECRET_KEY=sk_test_or_sk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_replace_me
# Optional — only needed if you serve Clerk Frontend API through a proxy / a
# custom domain. Safe to leave unset on localhost.
CLERK_PROXY_URL=
CLERK_DOMAIN=
CLERK_JWT_KEY=
CLERK_SIGN_IN_URL=

# ── Clerk auth (web client, exposed to the browser) ────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_replace_me
VITE_CLERK_PROXY_URL=

# ── Clerk auth (mobile / Expo client, exposed to the app bundle) ───────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_replace_me
EXPO_PUBLIC_CLERK_PROXY_URL=

# ── Expo / mobile runtime ──────────────────────────────────────────────────
# Hostname (no protocol) of the API server the mobile app talks to.
# On Replit the dev script auto-fills this from $REPLIT_DEV_DOMAIN; off
# Replit set it to the host of your deployed API (or your LAN IP for local
# device testing, e.g. "192.168.1.20:8080").
EXPO_PUBLIC_DOMAIN=
# Identifier for the Replit project. Only used when running on Replit; the
# build script falls back to $REPL_ID. Leave empty outside Replit.
EXPO_PUBLIC_REPL_ID=

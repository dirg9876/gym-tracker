{
  "expo": {
    "name": "Gym-Beam",
    "slug": "gym-beam",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymbeam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "backgroundColor": "#0a0a0a",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.dirg9876.gymbeam",
      "versionCode": 2,
      "backgroundColor": "#0a0a0a",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "dabd3128-415f-4a2f-8c73-3b0a52585149"
      }
    },
    "owner": "dirg9508"
  }
}
